rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Restrict access to authenticated users only.
    // Client-side transactions in the app require users to read/write other users' documents
    // (e.g., deducting coins, adding earnings), so restricting by user ID would break functionality.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
